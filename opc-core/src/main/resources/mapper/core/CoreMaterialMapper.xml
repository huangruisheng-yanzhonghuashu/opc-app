<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opc.core.mapper.CoreMaterialMapper">

	<resultMap type="CoreMaterial" id="CoreMaterialResult">
		<id     property="id"                column="id"                  />
		<result property="title"              column="title"               />
		<result property="author"             column="author"              />
		<result property="summary"            column="summary"             />
		<result property="content"           column="content"             />
		<result property="originalUrl"       column="original_url"        />
		<result property="publishTime"       column="publish_time"        />
		<result property="viewPermission"     column="view_permission"    />
		<result property="contentType"        column="content_type"        />
		<result property="coverImage"         column="cover_image"         />
		<result property="category"           column="category"            />
		<result property="status"             column="status"              />
		<result property="isTop"              column="is_top"              />
		<result property="source"             column="source"              />
		<result property="createBy"          column="create_by"           />
		<result property="createTime"        column="create_time"         />
		<result property="updateBy"          column="update_by"           />
		<result property="updateTime"        column="update_time"         />
		<result property="remark"            column="remark"              />
	</resultMap>

	<sql id="selectMaterialVo">
        select id, title, author, summary, content, original_url, publish_time,
               view_permission, content_type, cover_image, category, status, is_top, source,
               create_by, create_time, update_by, update_time, remark
		from core_material
    </sql>

	<select id="selectMaterialList" parameterType="CoreMaterial" resultMap="CoreMaterialResult">
		<include refid="selectMaterialVo"/>
		<where>
			<if test="title != null and title != ''">
				AND title like concat('%', #{title}, '%')
			</if>
			<if test="author != null and author != ''">
				AND author like concat('%', #{author}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="viewPermission != null">
				AND view_permission = #{viewPermission}
			</if>
			<if test="category != null and category != ''">
				AND category = #{category}
			</if>
			<if test="source != null and source != ''">
				AND source = #{source}
			</if>
		</where>
		order by is_top desc, create_time desc
	</select>

	<select id="selectMaterialById" parameterType="Long" resultMap="CoreMaterialResult">
		<include refid="selectMaterialVo"/>
		where id = #{id}
	</select>

	<update id="updateMaterial" parameterType="CoreMaterial">
 		update core_material
 		<set>
 			<if test="title != null and title != ''">title = #{title},</if>
 			<if test="author != null">author = #{author},</if>
 			<if test="summary != null">summary = #{summary},</if>
 			<if test="content != null">content = #{content},</if>
 			<if test="originalUrl != null">original_url = #{originalUrl},</if>
 			<if test="publishTime != null">publish_time = #{publishTime},</if>
 			<if test="viewPermission != null">view_permission = #{viewPermission},</if>
 			<if test="contentType != null">content_type = #{contentType},</if>
 			<if test="coverImage != null">cover_image = #{coverImage},</if>
 			<if test="category != null">category = #{category},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="isTop != null and isTop != ''">is_top = #{isTop},</if>
 			<if test="source != null">source = #{source},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where id = #{id}
	</update>

 	<insert id="insertMaterial" parameterType="CoreMaterial" useGeneratedKeys="true" keyProperty="id">
 		insert into core_material(
 			<if test="id != null and id != 0">id,</if>
 			<if test="title != null and title != ''">title,</if>
 			<if test="author != null">author,</if>
 			<if test="summary != null">summary,</if>
 			<if test="content != null">content,</if>
 			<if test="originalUrl != null">original_url,</if>
 			<if test="publishTime != null">publish_time,</if>
 			<if test="viewPermission != null">view_permission,</if>
 			<if test="contentType != null">content_type,</if>
 			<if test="coverImage != null">cover_image,</if>
 			<if test="category != null">category,</if>
 			<if test="status != null and status != ''">status,</if>
 			<if test="isTop != null and isTop != ''">is_top,</if>
 			<if test="source != null">source,</if>
 			<if test="remark != null">remark,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="id != null and id != 0">#{id},</if>
 			<if test="title != null and title != ''">#{title},</if>
 			<if test="author != null">#{author},</if>
 			<if test="summary != null">#{summary},</if>
 			<if test="content != null">#{content},</if>
 			<if test="originalUrl != null">#{originalUrl},</if>
 			<if test="publishTime != null">#{publishTime},</if>
 			<if test="viewPermission != null">#{viewPermission},</if>
 			<if test="contentType != null">#{contentType},</if>
 			<if test="coverImage != null">#{coverImage},</if>
 			<if test="category != null">#{category},</if>
 			<if test="status != null and status != ''">#{status},</if>
 			<if test="isTop != null and isTop != ''">#{isTop},</if>
 			<if test="source != null">#{source},</if>
 			<if test="remark != null">#{remark},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>

	<delete id="deleteMaterialById" parameterType="Long">
		delete from core_material where id = #{id}
	</delete>

	<delete id="deleteMaterialByIds" parameterType="Long">
		delete from core_material where id in
		<foreach item="id" collection="array" open="(" separator="," close=")">
			#{id}
		</foreach>
	</delete>

	<update id="changeStatus" parameterType="CoreMaterial">
		update core_material
		set status = #{status},
		    update_time = sysdate()
		where id = #{id}
	</update>

	<update id="changeTop" parameterType="CoreMaterial">
		update core_material
		set is_top = #{isTop},
		    update_time = sysdate()
		where id = #{id}
	</update>

</mapper>
