<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opc.core.mapper.CoreMemberMapper">

	<resultMap type="CoreMember" id="CoreMemberResult">
		<id     property="id"              column="id"                />
		<result property="username"        column="username"          />
		<result property="password"        column="password"          />
		<result property="nickname"        column="nickname"          />
		<result property="phoneNumber"     column="phone_number"      />
		<result property="email"           column="email"             />
		<result property="avatar"          column="avatar"            />
		<result property="lastActiveTime"  column="last_active_time"  />
		<result property="currentPackage"  column="current_package"   />
		<result property="currentPackageLevel" column="current_package_level" />
		<result property="source"          column="source"            />
		<result property="sourceId"        column="source_id"         />
		<result property="token"           column="token"             />
		<result property="status"          column="status"            />
		<result property="registerTime"    column="register_time"     />
		<result property="createBy"        column="create_by"         />
		<result property="createTime"      column="create_time"       />
		<result property="updateBy"        column="update_by"         />
		<result property="updateTime"      column="update_time"       />
		<result property="remark"          column="remark"            />
	</resultMap>

	<sql id="selectMemberVo">
        select id, username, password, nickname, phone_number, email, avatar, last_active_time,
               current_package, current_package_level, source, source_id, token, status, register_time,
               create_by, create_time, update_by, update_time, remark
		from core_member
    </sql>

	<select id="selectMemberList" parameterType="CoreMember" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		<where>
			<if test="username != null and username != ''">
				AND username like concat('%', #{username}, '%')
			</if>
			<if test="nickname != null and nickname != ''">
				AND nickname like concat('%', #{nickname}, '%')
			</if>
			<if test="phoneNumber != null and phoneNumber != ''">
				AND phone_number like concat('%', #{phoneNumber}, '%')
			</if>
			<if test="email != null and email != ''">
				AND email like concat('%', #{email}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="source != null and source != ''">
				AND source = #{source}
			</if>
		</where>
	</select>

	<select id="selectMemberById" parameterType="Long" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where id = #{id}
	</select>

	<select id="checkMemberNameUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where username = #{username} limit 1
	</select>

	<select id="checkPhoneUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where phone_number = #{phoneNumber} limit 1
	</select>

	<select id="checkEmailUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where email = #{email} limit 1
	</select>

	<update id="updateMember" parameterType="CoreMember">
 		update core_member
 		<set>
 			<if test="username != null and username != ''">username = #{username},</if>
 			<if test="password != null and password != ''">password = #{password},</if>
 			<if test="nickname != null">nickname = #{nickname},</if>
 			<if test="phoneNumber != null and phoneNumber != ''">phone_number = #{phoneNumber},</if>
 			<if test="email != null and email != ''">email = #{email},</if>
 			<if test="avatar != null">avatar = #{avatar},</if>
 			<if test="lastActiveTime != null">last_active_time = #{lastActiveTime},</if>
 			<if test="currentPackage != null">current_package = #{currentPackage},</if>
 			<if test="currentPackageLevel != null">current_package_level = #{currentPackageLevel},</if>
 			<if test="source != null">source = #{source},</if>
 			<if test="sourceId != null">source_id = #{sourceId},</if>
 			<if test="token != null">token = #{token},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="registerTime != null">register_time = #{registerTime},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where id = #{id}
	</update>

 	<insert id="insertMember" parameterType="CoreMember" useGeneratedKeys="true" keyProperty="id">
 		insert into core_member(
 			<if test="id != null and id != 0">id,</if>
 			<if test="username != null and username != ''">username,</if>
 			<if test="password != null and password != ''">password,</if>
 			<if test="nickname != null">nickname,</if>
 			<if test="phoneNumber != null and phoneNumber != ''">phone_number,</if>
 			<if test="email != null and email != ''">email,</if>
 			<if test="avatar != null">avatar,</if>
 			<if test="lastActiveTime != null">last_active_time,</if>
 			<if test="currentPackage != null">current_package,</if>
 			<if test="currentPackageLevel != null">current_package_level,</if>
 			<if test="source != null">source,</if>
 			<if test="sourceId != null">source_id,</if>
 			<if test="token != null">token,</if>
 			<if test="status != null and status != ''">status,</if>
 			<if test="registerTime != null">register_time,</if>
 			<if test="remark != null">remark,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="id != null and id != 0">#{id},</if>
 			<if test="username != null and username != ''">#{username},</if>
 			<if test="password != null and password != ''">#{password},</if>
 			<if test="nickname != null">#{nickname},</if>
 			<if test="phoneNumber != null and phoneNumber != ''">#{phoneNumber},</if>
 			<if test="email != null and email != ''">#{email},</if>
 			<if test="avatar != null">#{avatar},</if>
 			<if test="lastActiveTime != null">#{lastActiveTime},</if>
 			<if test="currentPackage != null">#{currentPackage},</if>
 			<if test="currentPackageLevel != null">#{currentPackageLevel},</if>
 			<if test="source != null">#{source},</if>
 			<if test="sourceId != null">#{sourceId},</if>
 			<if test="token != null">#{token},</if>
 			<if test="status != null and status != ''">#{status},</if>
 			<if test="registerTime != null">#{registerTime},</if>
 			<if test="remark != null">#{remark},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>

	<update id="blockMember" parameterType="Long">
		update core_member
		set status = '1',
		    update_time = sysdate()
		where id = #{id}
	</update>

	<update id="unblockMember" parameterType="Long">
		update core_member
		set status = '0',
		    update_time = sysdate()
		where id = #{id}
	</update>

	<select id="selectMemberByEmail" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where email = #{email}
	</select>

	<update id="updateLoginInfo">
		update core_member
		set last_active_time = sysdate(),
		    update_time = sysdate()
		where id = #{id}
	</update>

	<select id="selectMemberOverview" parameterType="Map" resultType="Map">
		SELECT
			DATE(register_time) as date,
			COUNT(*) as newUserCount,
			0 as activeUserCount,
			0 as normalUserCount,
			0 as vipUserCount
		FROM core_member
		WHERE register_time >= #{startDate}
		  AND register_time &lt; DATE_ADD(#{endDate}, INTERVAL 1 DAY)
		GROUP BY DATE(register_time)

		UNION ALL

		SELECT
			DATE(last_active_time) as date,
			0 as newUserCount,
			COUNT(DISTINCT id) as activeUserCount,
			0 as normalUserCount,
			0 as vipUserCount
		FROM core_member
		WHERE last_active_time >= #{startDate}
		  AND last_active_time &lt; DATE_ADD(#{endDate}, INTERVAL 1 DAY)
		GROUP BY DATE(last_active_time)

		UNION ALL

		SELECT
			#{endDate} as date,
			0 as newUserCount,
			0 as activeUserCount,
			COUNT(CASE WHEN current_package_level = 0 OR current_package_level IS NULL THEN 1 END) as normalUserCount,
			COUNT(CASE WHEN current_package_level > 0 OR current_package IS NOT NULL THEN 1 END) as vipUserCount
		FROM core_member
		WHERE status = '0'
	</select>

</mapper>
