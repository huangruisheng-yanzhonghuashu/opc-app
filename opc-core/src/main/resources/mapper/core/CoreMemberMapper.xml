<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opc.core.mapper.CoreMemberMapper">

	<resultMap type="CoreMember" id="CoreMemberResult">
		<id     property="memberId"        column="member_id"       />
		<result property="phoneNumber"     column="phone_number"    />
		<result property="email"           column="email"           />
		<result property="username"        column="username"        />
		<result property="nickname"         column="nickname"        />
		<result property="lastActiveTime"  column="last_active_time"/>
		<result property="currentPackage" column="current_package"/>
		<result property="level1Users"     column="level1_users"    />
		<result property="level2Users"    column="level2_users"    />
		<result property="level3Users"    column="level3_users"    />
		<result property="source"          column="source"          />
		<result property="sourceId"        column="source_id"       />
		<result property="status"          column="status"          />
		<result property="registerTime"   column="register_time"   />
		<result property="createBy"        column="create_by"       />
		<result property="createTime"     column="create_time"     />
		<result property="updateBy"        column="update_by"       />
		<result property="updateTime"      column="update_time"     />
		<result property="remark"          column="remark"          />
	</resultMap>

	<sql id="selectMemberVo">
        select member_id, phone_number, email, username, nickname, last_active_time,
               current_package, level1_users, level2_users, level3_users,
               source, source_id, status, register_time,
               create_by, create_time, update_by, update_time, remark
		from core_member
    </sql>

	<select id="selectMemberList" parameterType="CoreMember" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		<where>
			<if test="phoneNumber != null and phoneNumber != ''">
				AND phone_number like concat('%', #{phoneNumber}, '%')
			</if>
			<if test="email != null and email != ''">
				AND email like concat('%', #{email}, '%')
			</if>
			<if test="username != null and username != ''">
				AND username like concat('%', #{username}, '%')
			</if>
			<if test="nickname != null and nickname != ''">
				AND nickname like concat('%', #{nickname}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="source != null and source != ''">
				AND source = #{source}
			</if>
		</where>
	</select>

	<select id="selectMemberById" parameterType="Long" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where member_id = #{memberId}
	</select>

	<select id="checkMemberNameUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where username = #{username} limit 1
	</select>

	<select id="checkPhoneUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where phone_number = #{phoneNumber} limit 1
	</select>

	<select id="checkEmailUnique" parameterType="String" resultMap="CoreMemberResult">
		<include refid="selectMemberVo"/>
		where email = #{email} limit 1
	</select>

	<update id="updateMember" parameterType="CoreMember">
 		update core_member
 		<set>
 			<if test="phoneNumber != null and phoneNumber != ''">phone_number = #{phoneNumber},</if>
 			<if test="email != null and email != ''">email = #{email},</if>
 			<if test="username != null and username != ''">username = #{username},</if>
 			<if test="nickname != null">nickname = #{nickname},</if>
 			<if test="lastActiveTime != null">last_active_time = #{lastActiveTime},</if>
 			<if test="currentPackage != null">current_package = #{currentPackage},</if>
 			<if test="level1Users != null">level1_users = #{level1Users},</if>
 			<if test="level2Users != null">level2_users = #{level2Users},</if>
 			<if test="level3Users != null">level3_users = #{level3Users},</if>
 			<if test="source != null">source = #{source},</if>
 			<if test="sourceId != null">source_id = #{sourceId},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="registerTime != null">register_time = #{registerTime},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where member_id = #{memberId}
	</update>

 	<insert id="insertMember" parameterType="CoreMember" useGeneratedKeys="true" keyProperty="memberId">
 		insert into core_member(
 			<if test="memberId != null and memberId != 0">member_id,</if>
 			<if test="phoneNumber != null and phoneNumber != ''">phone_number,</if>
 			<if test="email != null and email != ''">email,</if>
 			<if test="username != null and username != ''">username,</if>
 			<if test="nickname != null">nickname,</if>
 			<if test="lastActiveTime != null">last_active_time,</if>
 			<if test="currentPackage != null">current_package,</if>
 			<if test="level1Users != null">level1_users,</if>
 			<if test="level2Users != null">level2_users,</if>
 			<if test="level3Users != null">level3_users,</if>
 			<if test="source != null">source,</if>
 			<if test="sourceId != null">source_id,</if>
 			<if test="status != null and status != ''">status,</if>
 			<if test="registerTime != null">register_time,</if>
 			<if test="remark != null">remark,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="memberId != null and memberId != 0">#{memberId},</if>
 			<if test="phoneNumber != null and phoneNumber != ''">#{phoneNumber},</if>
 			<if test="email != null and email != ''">#{email},</if>
 			<if test="username != null and username != ''">#{username},</if>
 			<if test="nickname != null">#{nickname},</if>
 			<if test="lastActiveTime != null">#{lastActiveTime},</if>
 			<if test="currentPackage != null">#{currentPackage},</if>
 			<if test="level1Users != null">#{level1Users},</if>
 			<if test="level2Users != null">#{level2Users},</if>
 			<if test="level3Users != null">#{level3Users},</if>
 			<if test="source != null">#{source},</if>
 			<if test="sourceId != null">#{sourceId},</if>
 			<if test="status != null and status != ''">#{status},</if>
 			<if test="registerTime != null">#{registerTime},</if>
 			<if test="remark != null">#{remark},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>

	<delete id="deleteMemberById" parameterType="Long">
		delete from core_member where member_id = #{memberId}
	</delete>

	<delete id="deleteMemberByIds" parameterType="Long">
 		delete from core_member where member_id in
 		<foreach collection="array" item="memberId" open="(" separator="," close=")">
 			#{memberId}
        </foreach>
 	</delete>

</mapper>
