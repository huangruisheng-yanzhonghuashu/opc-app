<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opc.core.mapper.CoreCollectSourceMapper">

	<resultMap type="CoreCollectSource" id="CoreCollectSourceResult">
		<id     property="id"                column="id"                  />
		<result property="keyword"            column="keyword"             />
		<result property="sourceUrl"         column="source_url"         />
		<result property="sourceType"        column="source_type"        />
		<result property="status"            column="status"              />
		<result property="createBy"          column="create_by"          />
		<result property="createTime"        column="create_time"        />
		<result property="updateBy"          column="update_by"          />
		<result property="updateTime"        column="update_time"        />
		<result property="remark"            column="remark"             />
	</resultMap>

	<sql id="selectCollectSourceVo">
        select id, keyword, source_url, source_type, status,
               create_by, create_time, update_by, update_time, remark
		from core_collect_source
    </sql>

	<select id="selectCollectSourceList" parameterType="CoreCollectSource" resultMap="CoreCollectSourceResult">
		<include refid="selectCollectSourceVo"/>
		<where>
			<if test="keyword != null and keyword != ''">
				AND keyword like concat('%', #{keyword}, '%')
			</if>
			<if test="sourceType != null and sourceType != ''">
				AND source_type = #{sourceType}
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
		</where>
		order by create_time desc
	</select>

	<select id="selectCollectSourceById" parameterType="Long" resultMap="CoreCollectSourceResult">
		<include refid="selectCollectSourceVo"/>
		where id = #{id}
	</select>

	<update id="updateCollectSource" parameterType="CoreCollectSource">
 		update core_collect_source
 		<set>
 			<if test="keyword != null and keyword != ''">keyword = #{keyword},</if>
 			<if test="sourceUrl != null and sourceUrl != ''">source_url = #{sourceUrl},</if>
 			<if test="sourceType != null and sourceType != ''">source_type = #{sourceType},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where id = #{id}
	</update>

 	<insert id="insertCollectSource" parameterType="CoreCollectSource" useGeneratedKeys="true" keyProperty="id">
 		insert into core_collect_source(
 			<if test="id != null and id != 0">id,</if>
 			<if test="keyword != null and keyword != ''">keyword,</if>
 			<if test="sourceUrl != null and sourceUrl != ''">source_url,</if>
 			<if test="sourceType != null and sourceType != ''">source_type,</if>
 			<if test="status != null and status != ''">status,</if>
 			<if test="remark != null">remark,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="id != null and id != 0">#{id},</if>
 			<if test="keyword != null and keyword != ''">#{keyword},</if>
 			<if test="sourceUrl != null and sourceUrl != ''">#{sourceUrl},</if>
 			<if test="sourceType != null and sourceType != ''">#{sourceType},</if>
 			<if test="status != null and status != ''">#{status},</if>
 			<if test="remark != null">#{remark},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>

	<delete id="deleteCollectSourceById" parameterType="Long">
		delete from core_collect_source where id = #{id}
	</delete>

	<delete id="deleteCollectSourceByIds" parameterType="Long">
		delete from core_collect_source where id in
		<foreach item="id" collection="array" open="(" separator="," close=")">
			#{id}
		</foreach>
	</delete>

	<update id="changeStatus" parameterType="CoreCollectSource">
		update core_collect_source
		set status = #{status},
		    update_time = sysdate()
		where id = #{id}
	</update>

</mapper>
